{
  "manifest_version": 3,
  "name": "Save Selection as HTML",
  "version": "1.0.0",
  "description": "框选网页内容（含图片），右键保存为排版完整的 HTML 文件",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  }
}

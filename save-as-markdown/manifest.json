{
  "manifest_version": 3,
  "name": "Save Selection as Markdown",
  "version": "1.0.0",
  "description": "框选网页文本，右键保存为 Markdown 文件",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
